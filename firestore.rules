rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == 'admin_news@globalnews.com');
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        request.auth.token.email == 'admin_news@globalnews.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Phase 4: Validation Helpers
    function isValidNewsArticle(data) {
      return data.keys().hasAll(['title', 'slug', 'category', 'content', 'excerpt', 'featuredImage', 'status', 'authorId', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 13
        && data.title is string && data.title.size() <= 200
        && data.slug is string && data.slug.size() <= 200
        && data.category is string && data.category.size() <= 50
        && data.content is string && data.content.size() <= 50000
        && data.excerpt is string && data.excerpt.size() <= 500
        && data.featuredImage is string && data.featuredImage.size() <= 2000
        && data.status in ['draft', 'published']
        && data.authorId == request.auth.uid
        && data.createdAt == request.time
        && data.updatedAt == request.time
        && (data.get('views', 0) is number);
    }

    function isValidSiteSettings(data) {
      return data.keys().hasAll(['siteName'])
        && data.siteName is string && data.siteName.size() <= 100
        && (!data.keys().contains('logoUrl') || (data.logoUrl is string && data.logoUrl.size() <= 2000))
        && (!data.keys().contains('contactEmail') || (data.contactEmail is string && data.contactEmail.size() <= 200))
        && (!data.keys().contains('accentColor') || (data.accentColor is string && data.accentColor.size() <= 20));
    }

    // 1. News Articles
    match /news/{articleId} {
      allow get: if true;
      allow list: if (resource.data.status == 'published') || isAdmin();

      allow create: if isEmailVerified() && isValidId(articleId) && isValidNewsArticle(incoming());
      
      allow update: if isEmailVerified() && (
        isAdmin() || (incoming().authorId == request.auth.uid && (
          // Action: Edit Article
          (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'slug', 'category', 'content', 'excerpt', 'featuredImage', 'images', 'status', 'updatedAt']) && 
           incoming().updatedAt == request.time) ||
          // Action: Update Views (Limited to specific field)
          (incoming().diff(existing()).affectedKeys().hasOnly(['views']) && incoming().views == existing().views + 1)
        ))
      );

      allow delete: if isEmailVerified() && (isAdmin() || existing().authorId == request.auth.uid);
    }

    // 2. Site Settings
    match /settings/global {
      allow read: if true;
      allow write: if isAdmin() && isValidSiteSettings(incoming());
    }

    // 3. Admin Access
    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // Only manageable via Admin SDK or Console
    }
  }
}
